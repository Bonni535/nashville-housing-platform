{
  "name": "Nashville Housing Platform",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  // Pass the .env file directly to the container so all Snowflake credentials
  // and API keys are available as environment variables without needing them
  // exported in the host shell first.
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.env"],

  // --frozen ensures reproducible installs matching the committed uv.lock
  "postCreateCommand": "pip install uv && uv sync --frozen && git config core.autocrlf false && git config core.fileMode false && git config core.trustctime false",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "innoverio.vscode-dbt-power-user",
        "snowflake.snowflake-vsc"
      ],
      "settings": {
        "python.venvPath": "${workspaceFolder}",
        "python.terminal.activateEnvironment": true,
        "dbt.projectsDir": "${workspaceFolder}/housing_pipeline",
        "dbt.dbtPythonPathOverride": "${workspaceFolder}/.venv/bin/python"
      }
    }
  },

  // 8082 — Airflow UI (run from host terminal, not inside container)
  "forwardPorts": [8082],
  "portsAttributes": {
    "8082": {
      "label": "Airflow UI",
      "onAutoForward": "notify"
    }
  }
}