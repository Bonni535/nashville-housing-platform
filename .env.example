# ── Snowflake ─────────────────────────────────────────────────────────────────
# Account identifier format: <orgname>-<account_name>  (e.g. abc123-us-east-1)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=HOUSING_PIPELINE_ROLE
SNOWFLAKE_DATABASE=HOUSING_PIPELINE
SNOWFLAKE_WAREHOUSE=HOUSING_PIPELINE_WH

# ── APIs ──────────────────────────────────────────────────────────────────────
# Census API key — free at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# ── Alerting ──────────────────────────────────────────────────────────────────
# Slack Incoming Webhook URL — stored as Airflow Variable in production
SLACK_WEBHOOK_URL=
