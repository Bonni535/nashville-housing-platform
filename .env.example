# ── Snowflake ──────────────────────────────────────────────────────────────
# Find your account identifier in Snowflake UI: Admin > Accounts
# Format: abc123.us-east-1  (no https://, no trailing slash)
SNOWFLAKE_ACCOUNT=your-account.region
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=HOUSING_PIPELINE_ROLE
SNOWFLAKE_WAREHOUSE=HOUSING_PIPELINE_WH
SNOWFLAKE_DATABASE=HOUSING_PIPELINE
SNOWFLAKE_SCHEMA=RAW

# ── Census ─────────────────────────────────────────────────────────────────
# Free key — sign up at api.census.gov/data/signup.html
CENSUS_API_KEY=your_census_key

# ── Alerting ───────────────────────────────────────────────────────────────
# Optional at dev time — leave blank and alerts will be skipped gracefully
# Must be an https:// URL if provided
SLACK_WEBHOOK_URL=

# ── Environment ────────────────────────────────────────────────────────────
# Must be exactly "dev" or "prod"
PIPELINE_ENV=dev
